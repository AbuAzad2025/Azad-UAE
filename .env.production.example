# Production-like local run — COPY to .env.production.local and fill values.
# Do NOT commit .env.production.local (gitignored).

APP_ENV=production
FLASK_ENV=production
DEBUG=false

# Required in production (assert_production_sanity)
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_HEX
CARD_ENCRYPTION_KEY=REPLACE_WITH_LONG_RANDOM_HEX
OWNER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_NOT_DEFAULT

# Master login — daily password derived from seed + date (not the seed itself)
AZAD_MASTER_DAILY_SEED=REPLACE_WITH_LONG_RANDOM_SECRET
AZAD_MASTER_LOGIN_DISABLED=0
# AZAD_MASTER_KEY_SHA256=   # optional static break-glass hash; omit if using daily seed only

# Local bind (production-like, not public 0.0.0.0)
HOST=127.0.0.1
PORT=5000
BASE_URL=http://127.0.0.1:5000

# Origins / CORS (match BASE_URL host)
PAYMENT_VAULT_TRUSTED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# Payments (placeholder until real provider)
NOWPAYMENTS_IPN_SECRET=CHANGE_ME_FOR_REAL_PROVIDER
# NOWPAYMENTS_API_KEY=

# PostgreSQL — adjust user/password/host/db to your machine
# Default project fallback if unset: postgresql+psycopg2://postgres@localhost:5432/azad_uae
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/azad_uae

# Optional local toggles
# SKIP_SYSTEM_INTEGRITY=1
DISABLE_TELEMETRY=1
WTF_CSRF_ENABLED=true

# NOTE: DEBUG=false enables SESSION_COOKIE_SECURE cookies.
# Plain http://127.0.0.1 may not persist login sessions — use HTTPS locally for full cookie testing.
