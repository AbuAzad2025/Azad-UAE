FLASK_APP=app:create_app
FLASK_ENV=production
DEBUG=False

# Security Keys
# Generate a long random string for production
SECRET_KEY=change-this-to-random-secret-key-in-production-VERY-LONG-AND-RANDOM
# Key for encrypting sensitive card data
CARD_ENCRYPTION_KEY=change-this-to-another-random-key

# Database (PostgreSQL is Required for Production)
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://db_user:db_password@localhost:5432/garage_simple

# Server Settings
HOST=0.0.0.0
PORT=8001

# Currency Settings
DEFAULT_CURRENCY=AED
CURRENCY_API_PROVIDER=exchangerate-api
CURRENCY_API_KEY=
CURRENCY_API_URL=https://v6.exchangerate-api.com/v6/{api_key}/latest/{base}

# Accounting currency cache (manual/internal rates — invoices, payments, GL)
CURRENCY_CACHE_TIMEOUT=3600

# Display-only online rates cache (navbar / fxModal) — 12 hours default
CURRENCY_ONLINE_CACHE_TIMEOUT=43200

# Company Information
COMPANY_NAME=Your Company Name
COMPANY_NAME_AR=اسم شركتك
COMPANY_ADDRESS=City - Country
COMPANY_PHONE=+971500000000
COMPANY_WHATSAPP=971500000000
COMPANY_EMAIL=company@example.com
COMPANY_WEBSITE=
COMPANY_TAX_NUMBER=

# Developer Information
DEVELOPER_NAME=Your Developer Name
DEVELOPER_COMPANY=Your Developer Company
DEVELOPER_WEBSITE=
DEVELOPER_PHONE=+971500000000
DEVELOPER_EMAIL=dev@example.com

# Master Owner Account (Will be created if not exists)
OWNER_USERNAME=owner
OWNER_PASSWORD=change-me-strong-password
OWNER_EMAIL=owner@example.com

# Break-glass master login (Owner only — daily rotating password)
# Enabled by default. Set AZAD_MASTER_LOGIN_DISABLED=1 to turn off.
# Daily password = cleartext  {seed}@{date}  e.g. Azad@1983@2025@05@31
# (SHA256 of that string is what the server compares against your typed password)
# Override seed: AZAD_MASTER_DAILY_SEED or instance/.master_daily_seed
# Static emergency hash (optional): AZAD_MASTER_KEY_SHA256
AZAD_MASTER_LOGIN_DISABLED=
AZAD_MASTER_KEY_SHA256=
AZAD_MASTER_DAILY_SEED=
AZAD_MASTER_DAILY_DATE_FORMAT=%Y@%m@%d
AZAD_MASTER_LOGIN_ALLOWLIST=127.0.0.1,::1
AZAD_MASTER_HASH_FILE=
AZAD_MASTER_SEED_FILE=

# SQLAlchemy AI/neural ORM listeners (learning file I/O on Sale insert, etc.)
# Production default: off unless explicitly true. Dev/staging default: on.
# AI_ORM_LISTENERS_ENABLED=false

# Redis (Cache & Celery)
REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=redis

# Mail Settings (Gmail Example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# WhatsApp Integration
WHATSAPP_ENABLED=False
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER=

# Security Settings
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_DURATION_MINUTES=15

# UI Settings
ITEMS_PER_PAGE=20
LOG_LEVEL=INFO
