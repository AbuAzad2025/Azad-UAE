{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"files": {
		"includes": [
			"static/js/**/*.js",
			"static/js/**/*.d.ts",
			"static/*.js",
			"!static/adminlte",
			"!static/datatables",
			"!static/theme"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noExplicitAny": "warn",
				"useIterableCallbackReturn": "error",
				"noFunctionAssign": "error"
			},
			"style": {
				"useTemplate": "error"
			},
			"complexity": {
				"noArguments": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	}
}
