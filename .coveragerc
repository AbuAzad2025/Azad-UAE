[run]
parallel = True
branch = True
relative_files = True
source =
    app
    ai_knowledge
    bootstrap
    forms
    models
    routes
    services
    utils
    config
    extensions
omit =
    migrations/**
    tests/**
    tools/**
    scripts/**
    load_tests/**
    .venv/**
    venv/**
    */site-packages/**
    node_modules/**

[paths]
source =
    app/
    ai_knowledge/
    bootstrap/
    forms/
    models/
    routes/
    services/
    utils/
    /home/runner/work/Azad-UAE/Azad-UAE/app/
    /home/runner/work/Azad-UAE/Azad-UAE/ai_knowledge/
    /home/runner/work/Azad-UAE/Azad-UAE/bootstrap/
    /home/runner/work/Azad-UAE/Azad-UAE/forms/
    /home/runner/work/Azad-UAE/Azad-UAE/models/
    /home/runner/work/Azad-UAE/Azad-UAE/routes/
    /home/runner/work/Azad-UAE/Azad-UAE/services/
    /home/runner/work/Azad-UAE/Azad-UAE/utils/

[report]
omit =
    migrations/**
    tests/**
    tools/**
    scripts/**
    load_tests/**
    exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    if __name__ == .__main__.:
    raise NotImplementedError
show_missing = True
skip_covered = False
precision = 2
