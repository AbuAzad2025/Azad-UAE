[run]
# Application Python inventory (packages + root modules):
#   app/  models/  routes/  services/  ai_knowledge/  utils/  forms/
#   bootstrap/  ai_training/  app.py  config.py  cli_commands.py  extensions.py
# Excluded via omit: static/AdminLTE, tests, migrations, scripts/, tools/, venv
source =
    app
    models
    routes
    services
    ai_knowledge
    utils
    forms
    bootstrap
    ai_training
    config
    cli_commands
    extensions
relative_files = true
omit =
    */static/*
    */node_modules/*
    */adminlte/*
    tests/*
    */test_*.py
    conftest.py
    migrations/*
    scripts/*
    tools/*
    */templates/*
    docs/*
    */fixtures/*
    */__pycache__/*
    .pytest_cache/*
    tests/.pytest-temp/*
    .venv/*
    venv/*
    env/*
    .tox/*
    .eggs/*
    *.egg-info/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    except ImportError:
    raise AssertionError
    raise ValueError
    raise TypeError
    raise KeyError
    raise IndexError
    raise RuntimeError
    raise Exception
    raise AttributeError
    raise ValidationError
    raise FieldValidationError
    raise Forbidden
    raise NotFound
    raise Unauthorized
    raise HTTPException
