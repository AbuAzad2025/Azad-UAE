[run]
source = .
    omit =
    migrations/*
    utils/build_assets.py
    utils/seed_industry_fields.py
    tests/*
    */tests/*
    .venv/*
    venv/*
    */site-packages/*

[report]
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    if __name__ == .__main__.:
show_missing = True
skip_covered = False
